// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}


datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  password  String?
  createdAt DateTime @default(now())

  profile   Profile?
  memberships FamilyMember[]
  posts     Post[]
  comments  Comment[]
  likes Like[]
}

model Profile {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id])

  userName String
  createdAt DateTime @default(now())
}

model Family {
  id    String @id @default(cuid())
  name  String

  members     FamilyMember[]
  posts       Post[]
  invitations Invitation[]
}

model FamilyMember {
  id        String @id @default(cuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  familyId  String
  family    Family @relation(fields: [familyId], references: [id])

  role      String @default("viewer") // admin / editor / viewer

  createdAt DateTime @default(now())

  @@unique([userId, familyId])
}

model Post {
  id        String   @id @default(cuid())

  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  imageUrl  String
  mediaType String @default("image")

  title     String?  @db.VarChar(50)

  createdAt DateTime @default(now())

  comments  Comment[]

  autoAlbumItems AutoAlbumItem[]

  likes Like[]
}

model Comment {
  id        String   @id @default(cuid())

  content   String

  postId    String
  post      Post     @relation(fields: [postId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Invitation {
  id        String   @id @default(cuid())
  code      String   @unique

  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])

  createdAt DateTime @default(now())
}

model AutoAlbum {
  id        String   @id @default(cuid())
  familyId String
  title     String
  keyword   String
  createdAt DateTime @default(now())

  items AutoAlbumItem[]
}

model AutoAlbumItem {
  id      String @id @default(cuid())

  albumId String
  album   AutoAlbum @relation(fields: [albumId], references: [id])

  postId  String
  post    Post @relation(fields: [postId], references: [id])

  @@unique([albumId, postId])
}

model Like {
  id        String   @id @default(cuid())

  postId    String
  post      Post     @relation(fields: [postId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}
